{#
/**
 * @file
 * Theme override to display a block.
 *
 * Available variables:
 * - plugin_id: The ID of the block implementation.
 * - label: The configured label of the block if visible.
 * - configuration: A list of the block's configuration values.
 *   - label: The configured label for the block.
 *   - label_display: The display settings for the label.
 *   - provider: The module or other provider that provided this block plugin.
 *   - Block plugin specific settings will also be stored here.
 * - in_preview: Whether the plugin is being rendered in preview mode.
 * - content: The content of this block.
 * - attributes: array of HTML attributes populated by modules, intended to
 *   be added to the main container tag of this template.
 *   - id: A valid HTML ID and guaranteed unique.
 * - title_attributes: Same as attributes, except applied to the main title
 *   tag that appears in the template.
 * - title_prefix: Additional output populated by modules, intended to be
 *   displayed in front of the main title tag that appears in the template.
 * - title_suffix: Additional output populated by modules, intended to be
 *   displayed after the main title tag that appears in the template.
 *
 * @see template_preprocess_block()
 */
#}
{%
  set classes = [
    'block',
    'block-' ~ configuration.provider|clean_class,
    'block-' ~ plugin_id|clean_class,
  ]
%}
<section class="section section-sm section-fluid bg-default">
  <div class="container-fluid">

    {% if label %}
      <h2 class="section section-sm section-fluid bg-default text-center">{{ label }}</h2>
    {% endif %}

    <div class="row row-sm row-30 justify-content-center" id="content_team"></div>

  </div>
</section>

<!-- WOW + Animate (IMPORTANTE) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/wow/1.1.2/wow.min.js"></script>

<script>
document.addEventListener("DOMContentLoaded", () => {
  listar_team();

  // Inicializar WOW
  if (typeof WOW !== "undefined") {
    new WOW().init();
  }
});

function listar_team() {
  let url2 = "/api/team";

  fetch(url2)
    .then(res => res.json())
    .then(data => {

      let html = data.map(item => item.item).join('');
      let container = document.getElementById("content_team");

      container.innerHTML = html;

      // 🔥 Re-inicializar WOW para contenido dinámico
      if (typeof WOW !== "undefined") {
        new WOW().init();
      }

    })
    .catch(error => {
      console.error('Error fetching Team data:', error);
    });
}
</script>

<style>
/* ===== TEAM CLASSIC ===== */

.team-classic {
    position: relative;
    overflow: hidden;
    max-width: 370px;
    margin: auto;
}

.team-classic-figure img {
    width: 100%;
    filter: grayscale(100%);
    transition: all .4s ease;
}

/* CAPTION */
.team-classic-caption {
    position: absolute;
    left: 0;
    bottom: 30px;
    width: 80%;
    min-width: 260px;
    margin-left: -40px;
    padding: 15px 20px 15px 50px;
    transition: all .4s ease;
    z-index: 2;
}

.team-classic-caption::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,.55);
    transform: skew(10deg);
    z-index: -1;
}

/* TEXTO */
.team-classic-name,
.team-classic-status {
    color: #fff;
}

.team-classic-name a {
    color: inherit;
}

/* ===== HOVER EFECTO (FIX PRINCIPAL) ===== */
.team-classic:hover .team-classic-figure img {
    filter: grayscale(0);
    transform: scale(1.05);
}

.team-classic:hover .team-classic-caption {
    margin-left: 0 !important;
}

/* RESPONSIVE */
@media (min-width: 576px) {
    .team-classic-lg {
        max-width: 420px;
    }
}
.team-classic-caption {
    pointer-events: none;
}
.team-classic {
    cursor: pointer;
}
.team-classic:hover img {
    filter: grayscale(0) !important;
    transform: scale(1.05);
}
</style>