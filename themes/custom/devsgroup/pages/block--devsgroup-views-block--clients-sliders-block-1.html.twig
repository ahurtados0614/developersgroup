<script>
document.addEventListener("DOMContentLoaded", listar_content_services);
function listar_content_services() {
  let url2 = "/api/client-slider";
  let itemClientAcum = "";
  const currentUrl = window.location.href;
    
    // Identificar la base URL sin parámetros ni hash.
    const url = new URL(currentUrl);
    let pathname = url.pathname;
    
  fetch(url2)
    .then(res => res.json())
    .then(dato => {
      for (let index = 0; index < dato.length; index++) {     
           itemClientAcum += dato[index].items;
      }
      document.getElementById("clients-experiences").innerHTML += itemClientAcum;
    })
    .catch(error => {
      console.error('Error fetching slider data:', error);
    });
}
</script>
