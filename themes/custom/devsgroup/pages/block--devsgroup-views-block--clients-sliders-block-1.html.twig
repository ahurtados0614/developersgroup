<!-- Years of experience--><!-- JavaScript para el contador --><script>
    // Función del contador animado
    function animateCounter(elementId, start, end, duration) {
        let startTime = null;
        const element = document.getElementById(elementId);
        function animation(currentTime) {
            if (!startTime) startTime = currentTime;
            const progress = currentTime - startTime;
            const current = Math.min(start + Math.ceil((end - start) * (progress / duration)), end);
            element.textContent = current;
            if (current < end) {
                requestAnimationFrame(animation);
            }
        }
        requestAnimationFrame(animation);
    }
    // Observador para disparar la animación cuando el elemento es visible
    document.addEventListener("DOMContentLoaded", function () {
        const target = document.getElementById("counter");
        const observer = new IntersectionObserver((entries, observer) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    // Cuando el elemento es visible, inicia la animación
                    animateCounter("counter", 0, 10, 2000);
                    observer.unobserve(target); // Detener la observación para que no se repita
                }
            });
        }, { threshold: 0.5 }); // Disparar cuando el 50% del elemento es visible
        observer.observe(target);
    });
</script>
